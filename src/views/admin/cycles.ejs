<h1 class="h4">الدورات التقييمية</h1><div class="card p-3 mb-3"><form method="post" class="row g-2"><div class="col-md-3"><input class="form-control" name="name" placeholder="اسم الدورة" required></div><div class="col-md-2"><input class="form-control" type="date" name="startDate" required></div><div class="col-md-2"><input class="form-control" type="date" name="endDate" required></div><div class="col-md-2"><input class="form-control" type="date" name="grievanceStartDate"></div><div class="col-md-2"><input class="form-control" type="date" name="grievanceEndDate"></div><div class="col-md-1"><button class="btn btn-primary w-100">إضافة</button></div></form></div><table class="table"><thead><tr><th>الاسم</th><th>الفترة</th><th>منشورة</th><th>نشطة</th><th></th></tr></thead><tbody><% cycles.forEach(c=>{ %><tr><td><%= c.name %></td><td><%= c.startDate %> - <%= c.endDate %></td><td><%= c.isPublished ? 'نعم':'لا' %></td><td><%= c.isActive ? 'نعم':'لا' %></td><td><form method="post" action="/admin/cycles/<%= c.id %>/publish" class="d-inline"><button class="btn btn-sm btn-success">نشر</button></form><form method="post" action="/admin/cycles/<%= c.id %>/close" class="d-inline"><button class="btn btn-sm btn-outline-danger">إغلاق</button></form></td></tr><% }) %></tbody></table>
