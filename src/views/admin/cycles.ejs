<%
  const cycleStatus = (c) => !c.isPublished ? 'لم تبدأ' : (c.isActive ? 'منشورة' : 'مغلقة');
%>
<h1 class="h4">الدورات التقييمية</h1>
<div class="card p-3 mb-3">
  <h2 class="h6">إضافة دورة</h2>
  <form method="post" class="row g-2">
    <div class="col-md-3"><input class="form-control" name="name" placeholder="اسم الدورة" required></div>
    <div class="col-md-2"><input class="form-control" type="date" name="startDate" required></div>
    <div class="col-md-2"><input class="form-control" type="date" name="endDate" required></div>
    <div class="col-md-2"><input class="form-control" type="date" name="grievanceStartDate" title="بداية التظلمات"></div>
    <div class="col-md-2"><input class="form-control" type="date" name="grievanceEndDate" title="نهاية التظلمات"></div>
    <div class="col-md-1"><button class="btn btn-primary w-100">إضافة</button></div>
  </form>
</div>
<table class="table align-middle">
  <thead><tr><th>الاسم</th><th>الفترة</th><th>حالة الدورة</th><th>إجراءات</th></tr></thead>
  <tbody><% cycles.forEach(c=>{ %>
    <tr>
      <td><%= c.name %></td><td><%= c.startDate %> - <%= c.endDate %></td><td><%= cycleStatus(c) %></td>
      <td>
        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#cycle-<%= c.id %>" type="button">تعديل التواريخ</button>
        <% if (!c.isPublished) { %><form method="post" action="/admin/cycles/<%= c.id %>/publish" class="d-inline"><button class="btn btn-sm btn-success">نشر</button></form><% } else { %><button class="btn btn-sm btn-secondary" disabled>منشورة</button><% } %>
        <% if (c.isActive) { %><form method="post" action="/admin/cycles/<%= c.id %>/close" class="d-inline"><button class="btn btn-sm btn-outline-danger">إغلاق</button></form><% } else { %><button class="btn btn-sm btn-outline-secondary" disabled>مغلقة</button><% } %>
      </td>
    </tr>
      <tr class="collapse" id="cycle-<%= c.id %>"><td colspan="4">
        <form method="post" action="/admin/cycles/<%= c.id %>/update" class="row g-2">
          <div class="col-md-3"><input class="form-control" name="name" value="<%= c.name %>" required></div>
          <div class="col-md-2"><input class="form-control" type="date" name="startDate" value="<%= c.startDate %>" <%= c.isPublished ? 'readonly' : 'required' %>></div>
          <div class="col-md-2"><input class="form-control" type="date" name="endDate" value="<%= c.endDate %>" required></div>
          <div class="col-md-2"><input class="form-control" type="date" name="grievanceStartDate" value="<%= c.grievanceStartDate || '' %>"></div>
          <div class="col-md-2"><input class="form-control" type="date" name="grievanceEndDate" value="<%= c.grievanceEndDate || '' %>"></div>
          <div class="col-md-1"><button class="btn btn-success w-100">حفظ</button></div>
        </form>
      </td></tr>
  <% }) %></tbody>
</table>
