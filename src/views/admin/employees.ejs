<h1 class="h4">إدارة الموظفين</h1><div class="card p-3 mb-4"><form method="post" class="row g-2"><div class="col-md-3"><input class="form-control" name="fullName" placeholder="الاسم" required></div><div class="col-md-2"><input class="form-control" name="nationalId" placeholder="الرقم الوطني" required></div><div class="col-md-2"><input class="form-control" name="employeeCode" placeholder="الرمز الوظيفي"></div><div class="col-md-2"><select class="form-select" name="role"><% Object.values(roles).forEach(r=>{ %><option value="<%= r %>"><%= r %></option><% }) %></select></div><div class="col-md-2"><select class="form-select" name="departmentId"><% lookups.departments.forEach(d=>{ %><option value="<%= d.id %>"><%= d.name %></option><% }) %></select></div><div class="col-md-2"><select class="form-select" name="jobTitleId"><% lookups.jobTitles.forEach(j=>{ %><option value="<%= j.id %>"><%= j.name %></option><% }) %></select></div><div class="col-md-2"><select class="form-select" name="departmentJobTitleId"><option value="">بدون ربط</option><% lookups.departmentJobTitles.forEach(dj=>{ %><option value="<%= dj.id %>">ربط #<%= dj.id %></option><% }) %></select></div><div class="col-md-2"><input class="form-control" name="managerId" placeholder="ID المدير"></div><div class="col-md-2"><button class="btn btn-primary w-100">إضافة</button></div></form></div><table class="table table-striped"><thead><tr><th>#</th><th>الاسم</th><th>الرقم الوطني</th><th>الدور</th><th>الدائرة</th><th>المدير</th></tr></thead><tbody><% employees.forEach(e=>{ %><tr><td><%= e.id %></td><td><%= e.fullName %></td><td><%= e.nationalId %></td><td><%= e.role %></td><td><%= e.departmentId %></td><td><%= e.managerId || '-' %></td></tr><% }) %></tbody></table>
