<h1 class="h4">تقييماتي</h1><% if (!cycle) { %><div class="alert alert-warning">لا توجد دورة منشورة حالياً.</div><% } else { %><p class="text-muted"><%= cycle.name %></p><table class="table"><thead><tr><th>المستفيد</th><th>نوع النموذج</th><th>الحالة</th><th></th></tr></thead><tbody><% targets.forEach(t=>{ %><tr><td><%= t.evaluatee.fullName %></td><td><%= t.label %></td><td><%= t.done ? 'تم الإرسال' : 'بانتظار التعبئة' %></td><td><% if(!t.done){ %><a class="btn btn-sm btn-primary" href="/evaluations/start?cycleId=<%= cycle.id %>&evaluateeId=<%= t.evaluatee.id %>&type=<%= t.type %>">تعبئة</a><% } %></td></tr><% }) %></tbody></table><% } %>
