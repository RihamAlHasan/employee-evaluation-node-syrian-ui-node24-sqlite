<div class="login-wrap">
  <div class="login-card">
    <div class="brand mb-4" style="color:var(--ink)">
      <span class="brand-mark">ت</span>
      <span><b>نظام تقييم الأداء</b><small>دخول آمن للمنصة</small></span>
    </div>
    <h1 class="h4 fw-bold mb-2">تسجيل الدخول</h1>
    <p class="text-muted">استخدمي الرقم الوطني أو الرمز الوظيفي. كلمة مرور الحسابات التجريبية: <b>123456</b></p>
    <form method="post" action="/login">
      <label class="form-label">المعرّف</label>
      <input class="form-control mb-3" name="identifier" value="11000000001" required>
      <label class="form-label">كلمة المرور</label>
      <input class="form-control mb-3" type="password" name="password" value="123456" required>
      <button class="btn btn-primary w-100 py-2">دخول إلى النظام</button>
    </form>
  </div>
</div>
