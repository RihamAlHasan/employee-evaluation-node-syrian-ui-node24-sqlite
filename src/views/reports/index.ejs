<h1 class="h4">التقارير واعتماد النتائج</h1><form class="mb-3"><select name="cycleId" class="form-select w-auto d-inline"><% cycles.forEach(c=>{ %><option value="<%= c.id %>" <%= String(c.id)===String(cycleId)?'selected':'' %>><%= c.name %></option><% }) %></select><button class="btn btn-outline-primary">عرض</button></form><table class="table table-striped"><thead><tr><th>الموظف</th><th>مدير</th><th>ذاتي</th><th>زملاء</th><th>النهائية</th><th>الحالة</th><th>اعتماد</th></tr></thead><tbody><% rows.forEach(r=>{ %><tr><td><%= r.employee.fullName %></td><td><%= r.managerScore ?? '-' %></td><td><%= r.selfScore ?? '-' %></td><td><%= r.peerAverage ?? '-' %></td><td><b><%= r.finalScore ?? '-' %></b></td><td><%= r.adjustment?.resultStatus || 'غير معتمدة' %></td><td><form method="post" action="/reports/approve" class="row g-1"><input type="hidden" name="cycleId" value="<%= cycleId %>"><input type="hidden" name="employeeId" value="<%= r.employee.id %>"><div class="col"><input class="form-control form-control-sm" name="adjustedFinalScore" placeholder="نتيجة معدلة" value="<%= r.finalScore ?? '' %>"></div><div class="col"><input class="form-control form-control-sm" name="strengthsHighlights" placeholder="إنجازات"></div><div class="col"><input class="form-control form-control-sm" name="improvementPoints" placeholder="تحسينات"></div><div class="col-auto"><button class="btn btn-sm btn-success">اعتماد</button></div></form></td></tr><% }) %></tbody></table>
