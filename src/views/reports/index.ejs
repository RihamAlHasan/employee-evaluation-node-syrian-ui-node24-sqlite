<h1 class="h4">التقارير واعتماد النتائج</h1>
<form class="mb-3">
  <select name="cycleId" class="form-select w-auto d-inline"><% cycles.forEach(c=>{ %><option value="<%= c.id %>" <%= String(c.id)===String(cycleId)?'selected':'' %>><%= c.name %></option><% }) %></select>
  <button class="btn btn-outline-primary">عرض</button>
</form>
<form id="bulk-approve-form" method="post" action="/reports/approve-bulk">
  <input type="hidden" name="cycleId" value="<%= cycleId %>">
</form>
  <div class="d-flex justify-content-between align-items-center mb-2">
    <p class="text-muted mb-0">يمكن تحديد أكثر من نتيجة تحتوي على تقييمات بحالة تمت المعالجة وغير معتمدة لاعتمادها دفعة واحدة.</p>
    <button class="btn btn-success btn-sm" form="bulk-approve-form">اعتماد النتائج المحددة</button>
  </div>
  <table class="table table-striped align-middle">
    <thead><tr><th>تحديد</th><th>الموظف</th><th>مدير</th><th>ذاتي</th><th>زملاء</th><th>النهائية</th><th>الحالة</th><th>اعتماد</th></tr></thead>
    <tbody><% rows.forEach(r=>{ const approved = r.adjustment?.resultStatus === 'Approved'; const processable = !approved && r.evaluations.some(e => e.status === 'Processed'); %>
      <tr>
        <td><input class="form-check-input" type="checkbox" name="employeeIds" form="bulk-approve-form" value="<%= r.employee.id %>" <%= processable ? '' : 'disabled' %>></td>
        <td><%= r.employee.fullName %></td><td><%= r.managerScore ?? '-' %></td><td><%= r.selfScore ?? '-' %></td><td><%= r.peerAverage ?? '-' %></td><td><b><%= r.finalScore ?? '-' %></b></td><td><%= r.adjustment?.resultStatus || 'غير معتمدة' %></td>
        <td>
          <% if (approved) { %>
            <button class="btn btn-sm btn-secondary" disabled>معتمدة</button>
          <% } else { %>
            <form method="post" action="/reports/approve" class="row g-1">
              <input type="hidden" name="cycleId" value="<%= cycleId %>"><input type="hidden" name="employeeId" value="<%= r.employee.id %>">
              <div class="col"><input class="form-control form-control-sm" name="adjustedFinalScore" placeholder="نتيجة معدلة" value="<%= r.finalScore ?? '' %>"></div>
              <div class="col"><input class="form-control form-control-sm" name="strengthsHighlights" placeholder="إنجازات"></div>
              <div class="col"><input class="form-control form-control-sm" name="improvementPoints" placeholder="تحسينات"></div>
              <div class="col-auto"><button class="btn btn-sm btn-success">اعتماد</button></div>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %></tbody>
  </table>
