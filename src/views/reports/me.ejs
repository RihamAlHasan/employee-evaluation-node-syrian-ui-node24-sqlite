<h1 class="h4">نتيجتي</h1><p class="text-muted"><%= cycle.name %></p><% if (!result.visible) { %><div class="alert alert-info"><%= result.reason %></div><% } else { %><div class="card p-4"><div class="display-5"><%= result.finalScore ?? '-' %>%</div><p>نتيجة المدير: <%= result.managerScore ?? '-' %> / الذاتي: <%= result.selfScore ?? '-' %> / متوسط الزملاء: <%= result.peerAverage ?? '-' %></p><% if (result.adjustment) { %><hr><b>إضاءات القوة:</b><p><%= result.adjustment.strengthsHighlights || '-' %></p><b>نقاط التحسين:</b><p><%= result.adjustment.improvementPoints || '-' %></p><% } %></div><% } %>
